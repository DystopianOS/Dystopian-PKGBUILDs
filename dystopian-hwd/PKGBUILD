pkgname=dystopian-hwd
pkgver=1.18.0
pkgrel=3
pkgdesc="Dystopian Hardware Detection Tool"
arch=(x86_64)
url="https://github.com/cachyos/chwd"
license=(GPL-3.0-or-later)
depends=('gcc-libs' 'pciutils' 'lua' 'pacman')
makedepends=('git' 'cargo' 'lld' 'clang' 'llvm')
optdepends=('zsh')
provides=('chwd-db')
replaces=('chwd-db')
conflicts=('chwd-db')
groups=('dystopian')
source=("chwd::git+$url.git#tag=${pkgver}?signed"
        "legion-go-inputplumber.patch")
sha256sums=('302dd6194cfaaed03e6c9751606e6c0e85adbbf35ae5e76d135cd799232c018e'
            '77269a0d73ddfa4965cdf69c60d4d2d5f30a920a4ea33f2eb1202f3913a3cb73')
b2sums=('d9c8e5b1a0c3e7f2a1b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6'
         'abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef')
validpgpkeys=(
  'C71C37EA17233736B9FAD43EFAD24DA0784D363A'  # Dystopian <dcxdevelopment at protonmail dot com>
  '14A71FEDA1F764F7075FFA40FF64D67D0F00DD12'  # DCx7C5 <dcxdevelopment at protonmail dot com>
)

prepare() {
  cd "$srcdir/chwd"

  git revert -n 399c20fd858e023a5e930e8510293230be98ccda
  patch -Np1 -i "${srcdir}/legion-go-inputplumber.patch"

  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"

  cd scripts/chwd-kernel
  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
  cd "$srcdir/chwd"

  # Compile with clang
  export AR=llvm-ar
  export CC=clang
  export CXX=clang++
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  export RUSTFLAGS="-Cembed-bitcode -C opt-level=3 -Ccodegen-units=1 -Clinker=clang -C link-arg=-flto -Clink-arg=-fuse-ld=/usr/bin/ld.lld"

  cd scripts/chwd-kernel
  cargo build --release --frozen

  cd ../../

  cargo build --release --frozen
}

package() {
  cd "$srcdir/chwd"

  install -Dm755 "target/release/chwd" "$pkgdir"/usr/bin/chwd
  install -Dm755 scripts/chwd "$pkgdir"/var/lib/chwd/scripts/chwd

  install -Dm644 target/release/build/chwd-*/out/chwd.bash "$pkgdir/usr/share/bash-completion/completions/chwd"
  # install -Dm644 target/release/build/chwd-*/out/chwd.fish "$pkgdir/usr/share/fish/vendor_completions.d/chwd.fish"
  # install -Dm644 target/release/build/chwd-*/out/_chwd "$pkgdir/usr/share/zsh/site-functions/_chwd"

  install -d -m755 "$pkgdir"/var/lib/chwd/{db,local}/pci

  # install ids
  install -d -m755 "$pkgdir"/var/lib/chwd/ids
  cp -r ids/* "$pkgdir"/var/lib/chwd/ids

  cp -r profiles/pci "$pkgdir"/var/lib/chwd/db/

  cd scripts/chwd-kernel
  install -Dm755 "target/release/chwd-kernel" "$pkgdir/usr/bin/chwd-kernel"
  ln -s /usr/bin/chwd-kernel "$pkgdir/usr/bin/dhwd-kernel"
  ln -s /usr/bin/chwd "$pkgdir/usr/bin/dystopian-hwd"
}


