pkgname=dystopian-hardware-profile-vm
pkgver=0.1.0
pkgrel=1
pkgdesc="Dystopian hardware profile for virtual machines (metapackage)"
arch=('any')
url="https://github.com/Dystopian-Project/dystopian-repo"
license=('GPL-3.0-or-later')
conflicts=(
    dystopian-hardware-profile-standard
    dystopian-gpu-profile-nvidia-580xx
    dystopian-gpu-profile-nvidia-nouveau
    dystopian-gpu-profile-radeon
)
depends=(
    mesa                  # OpenGL / OpenGL ES
    lib32-mesa            # 32-bit support
    vulkan-icd-loader     # Vulkan loader
    lib32-vulkan-icd-loader
    xf86-video-fbdev      # Fallback framebuffer
    mesa-vdpau            # Video acceleration (VDPAU)
    libva-mesa-driver     # VA-API
    libva-intel-driver    # Intel VA-API fallback (for hybrid setups)
)
optdepends=(
    "virtio-gpu: Virtio-GPU support for virtual machines (if available)"
    "lib32-virtio-gpu: 32-bit Virtio-GPU support for virtual machines (if available)"
    "qemu-guest-agent: Improves VM host/guest integration and enables controlled shutdowns (recommended for VMs)"
    "spice-vdagent: Clipboard/clipboard sharing and enhanced guest integration for SPICE sessions (if used)"
)