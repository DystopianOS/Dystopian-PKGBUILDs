[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = boot/vmlinuz-*
Target = boot/initramfs-*.img
Target = boot/*-ucode.img
Target = usr/lib/systemd/boot/efi/*.stub
Target = etc/kernel/cmdline*
Target = etc/os-release


[Action]
Description = Signing unified kernel bundle...
When = PostTransaction
Exec = /usr/bin/bash -c 'dystopian-hooks-runner "path" "$@"'
