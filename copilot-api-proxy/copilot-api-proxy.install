post_install() {
    # ANSI color codes
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m' # No Color

    # Create system user and group
    if ! getent group copilot-api-proxy >/dev/null 2>&1; then
        groupadd -r copilot-api-proxy
        echo -e "${GREEN}[+]${NC} Created group: copilot-api-proxy"
    fi

    if ! getent passwd copilot-api-proxy >/dev/null 2>&1; then
        useradd -r -g copilot-api-proxy -d /var/lib/copilot-api-proxy \
                -s /usr/bin/nologin -c "Copilot API Proxy" copilot-api-proxy
        echo -e "${GREEN}[+]${NC} Created user: copilot-api-proxy"
    fi

    # Add copilot-api-proxy user to caddy group if it exists
    if getent group caddy >/dev/null 2>&1; then
        usermod -a -G caddy copilot-api-proxy
        echo -e "${GREEN}[+]${NC} Added copilot-api-proxy to caddy group"
    fi

    # Create and set ownership of directories
    mkdir -p /var/lib/copilot-api-proxy
    mkdir -p /var/log/copilot-api-proxy
    mkdir -p /run/copilot-api-proxy

    chown copilot-api-proxy:copilot-api-proxy /var/lib/copilot-api-proxy
    chown copilot-api-proxy:copilot-api-proxy /var/log/copilot-api-proxy
    chown copilot-api-proxy:copilot-api-proxy /run/copilot-api-proxy

    chmod 750 /var/lib/copilot-api-proxy
    chmod 755 /var/log/copilot-api-proxy
    chmod 755 /run/copilot-api-proxy

    # Create token storage file if it doesn't exist
    if [ ! -f /var/lib/copilot-api-proxy/tokens.json ]; then
        echo '{}' > /var/lib/copilot-api-proxy/tokens.json
        chown copilot-api-proxy:copilot-api-proxy /var/lib/copilot-api-proxy/tokens.json
        chmod 600 /var/lib/copilot-api-proxy/tokens.json
        echo -e "${GREEN}[+]${NC} Created empty token storage"
    fi

    echo -e "${BLUE}[*]${NC} Dependencies managed with uv for faster performance"

    # Reload systemd
    systemctl daemon-reload

    echo ""
    echo -e "${GREEN}[+] Copilot API Proxy installed successfully!${NC}"
    echo -e "${YELLOW}[!]${NC} Next steps:"
    echo "    1. Edit /etc/copilot-api-proxy/config.env to configure GitHub App credentials"
    echo "    2. Enable and start the service:"
    echo "       sudo systemctl enable --now copilot-api-proxy.socket"
    echo "    3. Configure Caddy to use the proxy:"
    echo "       sudo ln -sf /etc/caddy/conf.d/copilot-api-proxy /etc/caddy/sites-available/"
    echo "       sudo systemctl enable --now caddy"
    echo "    4. Access the service at https://localhost:8443"
    echo ""
    echo -e "${BLUE}[*]${NC} For GitHub App setup instructions, see the documentation"
}

post_upgrade() {
    post_install
    echo -e "${YELLOW}[!]${NC} Package upgraded - restart services if needed:"
    echo "    sudo systemctl restart copilot-api-proxy"
}

pre_remove() {
    # Stop services before removal
    echo -e "${YELLOW}[-]${NC} Stopping Copilot API Proxy services..."
    systemctl stop copilot-api-proxy.service 2>/dev/null || true
    systemctl stop copilot-api-proxy.socket 2>/dev/null || true
    systemctl disable copilot-api-proxy.service 2>/dev/null || true
    systemctl disable copilot-api-proxy.socket 2>/dev/null || true
}

post_remove() {
    # ANSI color codes
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m' # No Color

    # Remove user and group (only if no other packages use them)
    if getent passwd copilot-api-proxy >/dev/null 2>&1; then
        userdel copilot-api-proxy 2>/dev/null || true
        echo -e "${RED}[-]${NC} Removed user: copilot-api-proxy"
    fi

    if getent group copilot-api-proxy >/dev/null 2>&1; then
        groupdel copilot-api-proxy 2>/dev/null || true
        echo -e "${RED}[-]${NC} Removed group: copilot-api-proxy"
    fi

    # Reload systemd
    systemctl daemon-reload

    echo ""
    echo -e "${RED}[-] Copilot API Proxy removed${NC}"
    echo -e "${BLUE}[*]${NC} Data preserved in:"
    echo "    - /var/lib/copilot-api-proxy/ (tokens and data)"
    echo "    - /var/log/copilot-api-proxy/ (logs)"
    echo "    - /etc/copilot-api-proxy/ (configuration)"
    echo -e "${YELLOW}[!]${NC} Remove manually if no longer needed"
}