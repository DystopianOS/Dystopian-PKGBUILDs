# Maintainer: Dystopian <dcxdevelopment at protonmail dot com>
# Co-Maintainer: DCx7C5 <dcxdevelopment at protonmail dot com>

_gitname=Dystopian-Settings
pkgbase=dystopian-settings
pkgname=(dystopian-base-settings
         dystopian-systemd-settings)

pkgdesc="Dystopian system settings and configuration (metapackage)"
pkgver=20260218
pkgrel=1
epoch=1
groups=('dystopian' 'dystopian-settings')
arch=('any')
license=('GPL-3.0-or-later')
makedepends=('coreutils' 'git')
url="https://github.com/DystopianOS/$_gitname"
source=("git+$url.git?signed#tag=$pkgver")
install="$pkgname.install"
sha512sums=('SKIP')
b2sums=('SKIP')
validpgpkeys=(
    '14A71FEDA1F764F7075FFA40FF64D67D0F00DD12'
    'C71C37EA17233736B9FAD43EFAD24DA0784D363A')
depends=(
    zram-generator
    ananicy-cpp
    dystopian-ananicy-rules
    inxi
    "systemd>=256")
optdepends=('libluv: for topmem'
            'lua-luv: for topmem'
            'power-profiles-daemon: For game-performance')
provides=('ntsync-common')

pkgver() {
  cd "$srcdir/${pkgbase}"
  date '+%Y%m%d'
}

prepare() {
  cd $_gitname
}

package_dystopian-core-settings() {
    pkgdesc="Dystopian Linux core system settings and configuration (metapackage)"
    backup=(
        'etc/pacman.conf'
        'etc/locale.gen'
    )

    cd "$srcdir/${pkgbase}/lib"

    install -Dm644 pacman.conf               "$pkgdir/etc/pacman.conf"
    install -Dm644 locale.gen                "$pkgdir/etc/locale.gen"
}
