# Maintainer: Dystopian <dcxdevelopment@protonmail.com>

pkgname=openclaude
pkgver=0.1.7
pkgrel=2
pkgdesc="Open-source Claude Code agent – community port of the leaked Anthropic Claude Code"
arch=('x86_64' 'aarch64')
url="https://github.com/Gitlawb/openclaude"
license=('MIT')
depends=('nodejs' 'ripgrep')
makedepends=('bun')
optdepends=('ollama: Run fully local models')
provides=('openclaude')
conflicts=('openclaude-git')
source=("openclaude-${pkgver}.tar.gz::https://github.com/Gitlawb/openclaude/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

options=(!strip)

prepare() {
  cd "${srcdir}/openclaude-${pkgver}"
  bun install --frozen-lockfile
}

build() {
  cd "${srcdir}/openclaude-${pkgver}"
  bun run build
}

package() {
  cd "${srcdir}/openclaude-${pkgver}"

  mkdir -p "${pkgdir}/usr/bin"
  mkdir -p "${pkgdir}/usr/lib/openclaude"

  # Wrapper-Script
  cat > "${pkgdir}/usr/bin/openclaude" << 'EOF'
#!/bin/sh
NODE_PATH="/usr/lib/openclaude/node_modules" exec node "/usr/lib/openclaude/cli.mjs" "$@"
EOF
  chmod +x "${pkgdir}/usr/bin/openclaude"

  # Gebündelte CLI installieren
  install -Dm755 dist/cli.mjs "${pkgdir}/usr/lib/openclaude/cli.mjs"

  # node_modules für Runtime-Abhängigkeiten (inkl. Symlinks)
  cp -a node_modules "${pkgdir}/usr/lib/openclaude/"

  # $srcdir-Referenzen in cli.mjs durch den finalen Installationspfad ersetzen.
  # bun bettet bei manchen Paketen (undici, @aws-sdk/util-user-agent-node) absolute
  # __filename / require.resolve()-Pfade ein, die auf $srcdir/node_modules zeigen.
  # Da node_modules nach /usr/lib/openclaude/node_modules kopiert wird, ist das
  # die korrekte Laufzeitadresse und der sed-Ersatz ist funktional korrekt.
  sed -i "s|${srcdir}/openclaude-${pkgver}/node_modules|/usr/lib/openclaude/node_modules|g" \
    "${pkgdir}/usr/lib/openclaude/cli.mjs"

  # Lizenz und Dokumentation
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md" 2>/dev/null || true
}
