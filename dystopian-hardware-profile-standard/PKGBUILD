# Maintainer: Dystopian <dcxdevelopment at protonmail dot com>
# Co-Maintainer: DCx7C5 <dcxdevelopment at protonmail dot com>

pkgname=dystopian-hardware-profile-standard
pkgver=0.1.0
pkgrel=1
pkgdesc="Dystopian standard hardware profile for physical machines (metapackage)"
arch=('any')
url="https://github.com/Dystopian-Project/dystopian-repo"
license=('GPL-3.0-or-later')
conflicts=(dystopian-hardware-profile-vm)
depends=(
    mesa                  # OpenGL / OpenGL ES
    lib32-mesa            # 32-bit support
    vulkan-icd-loader     # Vulkan loader
    lib32-vulkan-icd-loader
    xf86-video-fbdev      # Fallback framebuffer
    mesa-vdpau            # Video acceleration (VDPAU)
    libva-mesa-driver     # VA-API
    libva-intel-driver    # Intel VA-API fallback (for hybrid setups)
)

optdepends=(
    "linux-firmware: Recommended firmware for many devices (network, GPU, etc.)"
    "fwupd: Firmware update daemon (keeps device firmware up-to-date)"
    "tpm2-tools: TPM2 utilities for hardware TPM management (if available)"
    "ufw: Simple firewall (recommended)"
    "aide: File integrity monitoring (recommended for security audits)"
)

install=dystopian-hardware-profile-standard.install