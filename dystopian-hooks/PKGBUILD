pkgbase=dystopian-hooks
pkgver=0.1.0
pkgrel=1
pkgdesc="A package for Dystopian ALPM Hooks"
arch=('x86_64')
url="https://github.com/Dystopian-Project/Dystopian-PKGBUILDS"
license=('MIT')
makedepends=(
  'git'
)

depends=(
  'pacman'
  'binutils'
  'sbsigntools'
)

provides=('dystopian-hooks')
conflicts=('dystopian-hooks')

install="${pkgbase}.install"

_srcname=${pkgbase}-${pkgver%.*}
_srctag=v${pkgver%.*}-${pkgver##*.}

source=(
  'orphans-hook'
  'pacnew-check.hook'
  'bundle-remove.hook'
  '98-bundle-create.hook'
  '99-bundle-sign.hook'
  'dystopian-hooks-runner'
)

