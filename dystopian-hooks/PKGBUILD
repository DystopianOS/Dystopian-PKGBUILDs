# Maintainer: Dystopian <dcxdevelopment at protonmail dot com>
# Co-Maintainer: DCx7C5 <dcxdevelopment at protonmail dot com>
# Project: Dystopian Project

pkgname=dystopian-hooks
pkgver=0.1.0
pkgrel=1
pkgdesc="A package for Dystopian ALPM Hooks"
arch=('any')
license=('GPL-3.0-or-later')
url="https://github.com/DystopianOS/${pkgname}"
groups=('dystopian')
source=("git+https://github.com/DystopianOS/dystopian-hooks#tag=$pkgver")
makedepends=('git')
depends=('systemd')
provides=('dystopian-hooks')
conflicts=('dystopian-hooks')

sha512sums=('SKIP')

b2sums=('SKIP')

validpgpkeys=(
  '14A71FEDA1F764F7075FFA40FF64D67D0F00DD12'
  'C71C37EA17233736b9fad43efad24da0784d363a'
)

package() {
  cd "$pkgname"

  install -Dm644 dystopian-nvidia.hook "$pkgdir/usr/share/libalpm/hooks/dystopian-nvidia.hook"
  install -Dm644 dystopian-plymouth-initramfs.hook "$pkgdir/usr/share/libalpm/hooks/dystopian-plymouth-initramfs.hook"
  install -Dm644 dystopian-reboot-required.hook "$pkgdir/usr/share/libalpm/hooks/dystopian-reboot-required.hook"
  install -Dm755 dystopian-reboot-required "$pkgdir/usr/share/libalpm/scripts/dystopian-reboot-required"
  install -Dm755 update-initramfs "$pkgdir/usr/bin/update-initramfs"
}

# vim:set ts=8 sts=2 sw=2 et:
