# Maintainer: Dystopian <dcxdevelopment at protonmail dot com>
# Co-Maintainer: DCx7C5 <dcxdevelopment at protonmail dot com>
# Project: Dystopian Project

pkgname=dystopian-hooks
pkgver=0.1.0
pkgrel=1
pkgdesc="A package for Dystopian ALPM Hooks"
arch=('any')
license=('GPL-3.0-or-later')
url="https://github.com/DystopianOS/${pkgname}"
groups=('dystopian')
source=()
makedepends=('git')
depends=('systemd')
provides=('dystopian-hooks')
conflicts=('dystopian-hooks')

sha512sums=()
b2sums=()

validpgpkeys=(
  '14A71FEDA1F764F7075FFA40FF64D67D0F00DD12'
  'C71C37EA17233736b9fad43efad24da0784d363a'
)

prepare() {
  # Copy from dystopian-hooks repo at sibling level
  _srcdir="${startdir%/*}/dystopian-hooks"
  
  if [[ ! -d "$_srcdir" ]]; then
    echo "Error: dystopian-hooks repository not found at expected location"
    echo "Expected: $_srcdir"
    return 1
  fi
  
  mkdir -p "${srcdir}/hooks"
  cp -r "$_srcdir"/* "${srcdir}/hooks/" || true
}

package() {
  cd "${srcdir}/hooks"

  install -Dm644 dystopian-plymouth-initramfs.hook "$pkgdir/usr/share/libalpm/hooks/dystopian-plymouth-initramfs.hook"
  install -Dm644 dystopian-reboot-required.hook "$pkgdir/usr/share/libalpm/hooks/dystopian-reboot-required.hook"
  install -Dm644 nvidia-driver-switch.hook "$pkgdir/usr/share/libalpm/hooks/nvidia-driver-switch.hook"
  install -Dm644 98-bundle-create.hook "$pkgdir/usr/share/libalpm/hooks/98-bundle-create.hook"
  install -Dm644 99-bundle-sign.hook "$pkgdir/usr/share/libalpm/hooks/99-bundle-sign.hook"
  install -Dm644 bundle-remove.hook "$pkgdir/usr/share/libalpm/hooks/bundle-remove.hook"
  install -Dm644 orphans.hook "$pkgdir/usr/share/libalpm/hooks/orphans.hook"
  install -Dm644 pacnew-check.hook "$pkgdir/usr/share/libalpm/hooks/pacnew-check.hook"
  
  install -Dm755 dystopian-reboot-required "$pkgdir/usr/share/libalpm/scripts/dystopian-reboot-required"
  install -Dm755 update-initramfs "$pkgdir/usr/bin/update-initramfs"
  install -Dm755 nvidia-driver-switch "$pkgdir/usr/local/bin/nvidia-driver-switch"
  install -Dm755 dystopian-hooks-runner "$pkgdir/usr/bin/dystopian-hooks-runner"
}

