license=('GPL-3.0-or-later')
conflicts=(
    tpm2-tools
    tpm2-abrmd
    tpm2-tss
)
depends=(
    dystopian-libs          # Core libraries
    tpm2-tools              # Command-line tools for TPM 2.0 management
    tpm2-abrmd              # TPM 2.0 Access Broker and Resource Manager Daemon
    tpm2-tss                # TPM 2.0 Software Stack
    tpm2-openssl            # OpenSSL engine for TPM 2.0 support
    nss                     # Network Security Services (for TPM 2.0 integration with NSS)
)

