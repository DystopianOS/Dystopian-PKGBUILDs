# Maintainer: Dystopian <dcxdevelopment at protonmail dot com>
# Co-Maintainer: DCx7C5 <dcxdevelopment at protonmail dot com>

pkgbase=dystopian-keyring
pkgname=(dystopian-keyring
         dcx7c5-keyring)
pkgver=20251206
pkgrel=1
pkgdesc="GPG keys for Dystopian repositories"
arch=('any')
license=('GPL-3.0-or-later')
url="https://github.com/Dystopian-Project/dystopian-PKGBUILDS"

install=$pkgname.install

source=(dystopian.gpg
        dcx7c5.gpg
        dcx7c5-revoked
        dystopian-revoked
        dcx7c5-trusted
        dystopian-trusted)

sha512sums=('SKIP'
            'SKIP')
b2sums=('SKIP'
         'SKIP')

verifypgpkeys=('14A71FEDA1F764F7075FFA40FF64D67D0F00DD12'
               'C71C37EA17233736B9FAD43EFAD24DA0784D363A')

provides=('dystopian-keyring' 'dcx7c5-keyring')
conflicts=('dystopian-keyring' 'dcx7c5-keyring')


pkgver() {
  cd "$srcdir"
  date '+%Y%m%d'
}

_package-dystopian-keyring() {
    install -Dm444 dystopian.gpg "${pkgdir}/usr/share/pacman/keyrings/dystopian.gpg"
    chattr -i "${pkgdir}/usr/share/pacman/keyrings/dystopian.gpg"
}

_package-dcx7c5-keyring() {
    install -Dm444 dcx7c5.gpg "${pkgdir}/usr/share/pacman/keyrings/dcx7c5.gpg"
    chattr -i "${pkgdir}/usr/share/pacman/keyrings/dcx7c5.gpg"
}

for _p in "${pkgname[@]}"; do
    eval "package_$_p() {
    $(declare -f "_package${_p#$pkgbase}")
    _package${_p#$pkgbase}
    }"
done