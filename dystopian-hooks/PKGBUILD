package() {
  cd "${srcdir}" || exit

  install -d "${pkgdir}"/usr/share/libalpm/hooks
  install -Dm644 orphans.hook "${pkgdir}"/usr/share/libalpm/hooks/orphans.hook
  install -Dm644 pacnew-check.hook "${pkgdir}"/usr/share/libalpm/hooks/pacnew-check.hook
  install -Dm644 98-bundle-create.hook "${pkgdir}"/usr/share/libalpm/hooks/98-bundle-create.hook
  install -Dm644 99-bundle-sign.hook "${pkgdir}"/usr/share/libalpm/hooks/99-bundle-sign.hook
  install -Dm644 bundle-remove.hook "${pkgdir}"/usr/share/libalpm/hooks/bundle-remove.hook

  install -d "${pkgdir}"/usr/share/libalpm/scripts
  install -Dm755 dystopian-sbhooks-runner "${pkgdir}"/usr/share/libalpm/scripts/dystopian-sbhooks-runner

  install -d "${pkgdir}"/var/lib/dystopian
}

